{
  "consumer": {
    "name": "AccountService"
  },
  "interactions": [
    {
      "description": "a request for user balance",
      "providerStates": [
        {
          "name": "user with ID 123 exists"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/balance/123"
      },
      "response": {
        "body": {
          "accountType": "current",
          "amount": 1500.5,
          "currency": "BGN",
          "userId": 123
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.accountType": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(current|savings|business)$"
                }
              ]
            },
            "$.amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.currency": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {}
        },
        "status": 200
      }
    },
    {
      "description": "a request for user transactions",
      "providerStates": [
        {
          "name": "user with ID 123 has transactions"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/transactions/123"
      },
      "response": {
        "body": [
          {
            "amount": 250,
            "timestamp": "2026-06-10T10:00:00Z",
            "transactionId": "txn-abc-123",
            "type": "credit",
            "userId": 123
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].transactionId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(credit|debit)$"
                }
              ]
            },
            "$[*].userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {}
        },
        "status": 200
      }
    },
    {
      "description": "a request for balance of another user",
      "providerStates": [
        {
          "name": "user with ID 456 is not authorized"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/balance/456"
      },
      "response": {
        "body": {
          "error": "Forbidden"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {}
        },
        "status": 403
      }
    },
    {
      "description": "a request for balance of a non-existent user",
      "providerStates": [
        {
          "name": "user with ID 999 does not exist"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/balance/999"
      },
      "response": {
        "body": {
          "error": "User not found"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {}
        },
        "status": 404
      }
    },
    {
      "description": "a request for transactions of a non-existent user",
      "providerStates": [
        {
          "name": "user with ID 999 has no transactions"
        }
      ],
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/transactions/999"
      },
      "response": {
        "body": {
          "error": "User not found"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {}
        },
        "status": 404
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "11.0.2"
    },
    "pactRust": {
      "ffi": "0.4.0",
      "models": "1.0.4"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "BalanceService"
  }
}